{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["es2020", "dom"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "types": ["node", "react", "react-native"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}